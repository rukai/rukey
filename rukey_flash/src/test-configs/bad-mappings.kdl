version 0
device rukey
nickname "My rukey"
color 0xFF0000
profiles {
    - {
        mappings {
          - on-pressa : row0-col0 -> mouse-scroll-up 20
          - on-press : row0-col1 + -> mouse-scroll-down 20
          - on-press : row0-col2 mouse-scroll-left 20
          - on-press : row0-col3 -> mouse-scroll-right
          - on-press : row0-col99 -> keyboard-a
          - on-press row0-col99 -> keyboard-a
          - on-press :
        }
    }
}

pin-remappings { }

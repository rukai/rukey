version 0
device rukey
nickname "My rukey"
color 0xFF0000
profiles {
    - {
        mappings {
          - on-press : left-row0-col0 -> mouse-scroll-up 20
          - on-press : left-row0-col1 -> mouse-scroll-down 20
          - on-press : left-row0-col2 -> mouse-scroll-left 20
          - on-press : left-row0-col3 -> mouse-scroll-right 20
          - on-press : left-row1-col0 -> keyboard-page-up
          - on-press : left-row1-col1 -> keyboard-page-down

          - on-hold 50 : left-row1-col0 + left-row1-col1 -> after-millis-hold 50 + set-profile 2
        }
    }
}

pin-remappings {
    - {
        input left-row2-col0
        pin 3
    }
    - {
        input left-row2-col1
        pin 20
    }
 }
